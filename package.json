{
  "name": "resto-presta-bingen-all",
  "version": "1.0.0",
  "private": true,
  "engines": {
    "node": ">=22 <24"
  },
  "scripts": {
    "dev": "next dev",
    "build": "next build",
    "start": "next start",
    "lint": "next lint",
    "clean": "rm -rf .next",
    "refresh": "npm run clean && npm ci && npm run build && if command -v pm2 >/dev/null 2>&1; then pm2 restart resto-bingen --update-env && pm2 save; fi",
    "refresh:dev": "npm run clean && npm ci && npm run dev",
    "test": "tsx --test tests/*.test.ts",
    "seed": "tsx scripts/seed.ts",
    "qr": "tsx scripts/generate-qr.ts"
  },
  "dependencies": {
    "@supabase/supabase-js": "^2.39.0",
    "@supabase/ssr": "^0.1.0",
    "next": "14.1.0",
    "react": "^18.2.0",
    "react-dom": "^18.2.0",
    "next-auth": "^4.24.5",
    "date-fns": "^3.0.6",
    "mercadopago": "^2.0.0",
    "qrcode": "^1.5.3",
    "zod": "^3.22.4",
    "clsx": "^2.1.0",
    "tailwind-merge": "^2.2.0"
  },
  "devDependencies": {
    "@types/node": "^20.10.0",
    "@types/react": "^18.2.0",
    "@types/react-dom": "^18.2.0",
    "@types/qrcode": "^1.5.5",
    "typescript": "^5.3.0",
    "tailwindcss": "^3.4.0",
    "postcss": "^8.4.0",
    "autoprefixer": "^10.4.0",
    "tsx": "^4.7.0"
  }
}
